  "lyrics": [
    {
      "id": 1,
      "song": "倔强",
      "content": "当我和世界不一样\n那就让我不一样\n坚持对我来说就是以刚克刚",
      "mood": "励志",
      "featured": true
    },
    {
      "id": 2,
      "song": "温柔",
      "content": "走在风中 今天阳光突然好温柔\n天的温柔 地的温柔\n像你抱着我 然后发现",
      "mood": "温暖",
      "featured": true
    },
    {
      "id": 3,
      "song": "突然好想你",
      "content": "最怕空气突然安静\n最怕朋友突然的关心\n最怕回忆突然翻滚绞痛着不平息",
      "mood": "思念",
      "featured": true
    },
    {
      "id": 4,
      "song": "知足",
      "content": "怎么去拥有一道彩虹\n怎么去拥抱一夏天的风\n天上的星星笑地上的人\n总是不能懂不能觉得足够",
      "mood": "治愈",
      "featured": false
    },
    {
      "id": 5,
      "song": "你不是真正的快乐",
      "content": "你不是真正的快乐\n你的笑只是你穿的保护色\n你决定不恨了 也决定不爱了",
      "mood": "深沉",
      "featured": false
    },
    {
      "id": 6,
      "song": "人生海海",
      "content": "人生海海浮沉起落\n起起落落\n日日年年反反覆覆\n万般花样",
      "mood": "哲思",
      "featured": true
    },
    {
      "id": 7,
      "song": "后来的我们",
      "content": "后来的我们什么都有了\n却没有了我们\n好想再回到那个夏天",
      "mood": "怀旧",
      "featured": false
    },
    {
      "id": 8,
      "song": "恋爱ing",
      "content": "恋爱ing happy ing\n心情就像是坐上一台喷射机\n恋爱ing 开心ing\n虽然偶尔会有乱流的出现",
      "mood": "甜蜜",
      "featured": false
    }
